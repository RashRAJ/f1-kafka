# Build stage
FROM golang:1.24-alpine AS builder

WORKDIR /app

# Copy go mod files
COPY f1sim/go.mod f1sim/go.sum ./
RUN go mod download

# Copy source code
COPY f1sim/ ./

# Build the producer
RUN CGO_ENABLED=0 GOOS=linux go build -o producer ./cmd/producer

# Runtime stage
FROM alpine:latest

WORKDIR /app

# Copy the binary from builder
COPY --from=builder /app/producer .

# Copy .env file
COPY .env .

# Run the producer
CMD ["./producer"]
